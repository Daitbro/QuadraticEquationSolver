<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="QuadraticEquationSolver.Views.MainWindow"
        Title="Квадратное уравнение"
        Width="400" Height="360">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Решение квадратного уравнения" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="ax² + bx + c = 0" FontSize="14" HorizontalAlignment="Center"/>
        <TextBox x:Name="A" Watermark="Коэффициент a ="/>
        <TextBox x:Name="B" Watermark="Коэффициент b ="/>
        <TextBox x:Name="C" Watermark="Коэффициент c ="/>
        <Button x:Name="SolveBtn" Content="Решить" HorizontalAlignment="Center" Width="120" Margin="0,10"/>
        <Border Background="#F0F0F0" CornerRadius="5" Padding="10" MinHeight="100">
            <TextBox x:Name="Result" TextWrapping="Wrap" IsReadOnly="True" Background="Transparent" BorderThickness="0"/>
        </Border>
    </StackPanel>
</Window>